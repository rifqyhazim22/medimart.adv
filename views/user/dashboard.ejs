<%- include('../partials/header', { activeTab: 'dashboard' }) %>

    <style>
        /* Embedded Premium Dashboard Styles */
        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Header & Stats */
        .dashboard-header {
            background: transparent;
            padding: 0;
            box-shadow: none;
            color: var(--text-dark);
            margin-bottom: 40px;
        }

        .dashboard-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 8px;
            background: none;
            -webkit-text-fill-color: initial;
        }

        .dashboard-header p {
            color: var(--text-gray);
            font-size: 16px;
        }

        .dashboard-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            margin-top: 32px;
        }

        .stat-card {
            background: var(--bg-white);
            padding: 24px;
            border-radius: 16px;
            border: 1px solid var(--border);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            display: flex;
            align-items: center;
            gap: 20px;
            transition: transform 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .stat-icon.blue {
            background: #eff6ff;
            color: #3b82f6;
        }

        .stat-icon.orange {
            background: #fff7ed;
            color: #f97316;
        }

        .stat-icon.green {
            background: #f0fdf4;
            color: #22c55e;
        }

        .stat-content h3 {
            margin: 0;
            color: var(--text-gray);
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 4px;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--text-dark);
            margin: 0;
        }

        /* Orders List */
        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border);
        }



        .btn-ghost-danger {
            display: inline-flex;
            align-items: center;
            padding: 10px 16px;
            background: transparent;
            color: #ef4444;
            font-weight: 500;
            font-size: 14px;
            border-radius: 8px;
            border: 1px solid transparent;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-ghost-danger:hover {
            background: #fef2f2;
            border-color: #fee2e2;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: var(--bg-white);
            border-radius: 16px;
            border: 1px dashed var(--border);
            margin-top: 40px;
        }

        .empty-icon {
            font-size: 48px;
            margin-bottom: 16px;
            display: block;
        }
    </style>

    <div class="main-container">
        <div class="dashboard-container">
            <!-- Header & Stats -->
            <div class="dashboard-header">
                <h1 data-i18n="user.dashboard_title">Pesanan Saya</h1>
                <p><span data-i18n="user.greeting">Halo</span>, <strong>
                        <%= currentUser.full_name || currentUser.username %>
                    </strong>! <span data-i18n="user.greeting_desc">Kelola riwayat belanjaan Anda di sini.</span></p>

                <div class="dashboard-stats">
                    <div class="stat-card">
                        <div class="stat-icon blue">📦</div>
                        <div class="stat-content">
                            <h3 data-i18n="user.total_orders">Total Pesanan</h3>
                            <div class="stat-value">
                                <%= stats.totalOrders %>
                            </div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon orange">⏳</div>
                        <div class="stat-content">
                            <h3 data-i18n="user.active_orders">Pesanan Aktif</h3>
                            <div class="stat-value">
                                <%= stats.activeOrders %>
                            </div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon green">💰</div>
                        <div class="stat-content">
                            <h3 data-i18n="user.total_spent">Total Belanja</h3>
                            <div class="stat-value">Rp <%= parseInt(stats.totalSpent).toLocaleString('id-ID') %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Orders Preview -->
            <div
                style="margin-top: 24px; background: var(--bg-white); padding: 24px; border-radius: 16px; border: 1px solid var(--border); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; color: var(--text-dark); font-size: 18px;"><span
                            data-i18n="user.recent_orders">Pesanan Terbaru</span> 🛍️</h3>
                    <a href="/user/orders"
                        style="color: #00B09B; text-decoration: none; font-size: 14px; font-weight: 600; padding: 6px 12px; background: var(--bg-light); border: 1px solid var(--border); border-radius: 8px; transition: background 0.2s;"
                        onmouseover="this.style.background='var(--border)'"
                        onmouseout="this.style.background='var(--bg-light)'"><span data-i18n="user.view_all_orders">📦
                            Lihat Semua Pesanan</span> &rarr;</a>
                </div>


                <% if (recentOrders.length===0) { %>
                    <div class="empty-state" style="border: none; box-shadow: none; margin-top: 0;">
                        <span class="empty-icon">🛍️</span>
                        <h3 style="color: var(--text-dark); margin: 0 0 8px 0;" data-i18n="user.no_orders">
                            Belum ada pesanan</h3>
                        <p style="color: var(--text-gray); margin: 0 0 20px 0;" data-i18n="user.no_orders_desc">Yuk,
                            mulai belanja kebutuhan kesehatanmu sekarang!</p>
                        <a href="/" class="btn-detail"
                            style="display: inline-flex; align-items: center; padding: 10px 20px; background: #00B09B; color: white; font-weight: 600; font-size: 14px; border-radius: 8px; text-decoration: none; transition: all 0.2s; border: none; box-shadow: 0 4px 6px -1px rgba(0, 176, 155, 0.2);"
                            data-i18n="user.shop_again">🛍️ Belanja Sekarang</a>
                    </div>
                    <% } else { %>
                        <div style="overflow-x: auto;">
                            <table style="width: 100%; border-collapse: collapse; min-width: 600px;">
                                <thead>
                                    <tr style="border-bottom: 2px solid var(--border); background: var(--bg-light);">
                                        <th
                                            style="padding: 12px 16px; color: var(--text-gray); font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; text-align: center;">
                                            NO. INVOICE</th>
                                        <th style="padding: 12px 16px; color: var(--text-gray); font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; text-align: left;"
                                            data-i18n="user.items_count">ITEM</th>
                                        <th style="padding: 12px 16px; color: var(--text-gray); font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; text-align: center;"
                                            data-i18n="user.total_spent">TOTAL BELANJA</th>
                                        <th style="padding: 12px 16px; color: var(--text-gray); font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; text-align: center;"
                                            data-i18n="user.th_status">STATUS ORDER</th>
                                        <th style="padding: 12px 16px; color: var(--text-gray); font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; text-align: center;"
                                            data-i18n="user.th_date">TANGGAL BERLANGSUNG</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% recentOrders.forEach(order=> { %>
                                        <tr style="border-bottom: 1px solid var(--border); transition: background 0.2s;"
                                            onmouseover="this.style.background='var(--bg-light)'"
                                            onmouseout="this.style.background='transparent'">
                                            <td
                                                style="padding: 16px; font-weight: 600; color: var(--text-dark); font-size: 14px; text-align: center;">
                                                #ORD-<%= order.id %>
                                            </td>
                                            <td
                                                style="padding: 16px; color: var(--text-gray); font-size: 14px; text-align: left;">
                                                <span style="font-weight: 700; color: #00B09B;">
                                                    <%= order.items ? order.items.length : 0 %>
                                                </span> Item
                                            </td>
                                            <td
                                                style="padding: 16px; font-weight: 700; color: var(--text-dark); font-size: 14px; text-align: center;">
                                                Rp <%= parseInt(order.total_price).toLocaleString('id-ID') %>
                                            </td>
                                            <td style="padding: 16px; text-align: center;">
                                                <%- renderOrderBadge(order.status, 'buyer' , order.items, t) %>
                                            </td>
                                            <td
                                                style="padding: 16px; color: var(--text-gray); font-size: 13px; text-align: center;">
                                                <%= new Date(order.createdAt).toLocaleDateString(typeof lang
                                                    !=='undefined' && lang==='en' ? 'en-US' : 'id-ID' , {
                                                    year: 'numeric' , month: 'long' , day: 'numeric' , timeZone: userTz
                                                    }) %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('checkout') === 'success') {
                // Fire Confetti!
                if (typeof confetti !== 'undefined') {
                    confetti({ particleCount: 150, spread: 80, origin: { y: 0.6 }, colors: ['#FF6B35', '#22c55e', '#E040FB', '#0d9488'] });
                }

                // Show Success SweetAlert
                Swal.fire({
                    icon: 'success',
                    title: t('toast.checkout_success') || 'Checkout Berhasil!',
                    html: `<span style="color: var(--text-gray); font-size:15px;">${t('toast.checkout_success_desc') || 'Pesanan Anda sedang diproses oleh penjual.'}</span>`,
                    confirmButtonColor: '#00B09B',
                    confirmButtonText: 'Lanjutkan',
                    showClass: { popup: 'animate__animated animate__zoomIn animate__faster' }
                });

                // Clean URL
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        });
    </script>

    <%- include('../partials/footer') %>