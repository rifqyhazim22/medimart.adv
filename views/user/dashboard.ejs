<%- include('../partials/header', { activeTab: 'dashboard' }) %>

    <style>
        /* Embedded Premium Dashboard Styles */
        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Header & Stats */
        .dashboard-header {
            background: transparent;
            padding: 0;
            box-shadow: none;
            color: var(--text-dark);
            margin-bottom: 40px;
        }

        .dashboard-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 8px;
            background: none;
            -webkit-text-fill-color: initial;
        }

        .dashboard-header p {
            color: var(--text-gray);
            font-size: 16px;
        }

        .dashboard-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            margin-top: 32px;
        }

        .stat-card {
            background: var(--bg-white);
            padding: 24px;
            border-radius: 16px;
            border: 1px solid var(--border);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            display: flex;
            align-items: center;
            gap: 20px;
            transition: transform 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .stat-icon.blue {
            background: #eff6ff;
            color: #3b82f6;
        }

        .stat-icon.orange {
            background: #fff7ed;
            color: #f97316;
        }

        .stat-icon.green {
            background: #f0fdf4;
            color: #22c55e;
        }

        .stat-content h3 {
            margin: 0;
            color: var(--text-gray);
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 4px;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--text-dark);
            margin: 0;
        }

        /* Orders List */
        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border);
        }

        .order-card {
            background: var(--bg-white);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
            padding: 24px;
            margin-bottom: 24px;
            transition: all 0.2s;
        }

        .order-card:hover {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            border-color: var(--border);
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #f9fafb;
        }

        .order-info {
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .order-icon-box {
            width: 48px;
            height: 48px;
            background: var(--border);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .order-details h3 {
            margin: 0;
            font-size: 16px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .order-date {
            margin: 4px 0 0;
            color: var(--text-gray);
            font-size: 13px;
        }

        .status-badge {
            padding: 6px 12px;
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .status-badge.completed,
        .status-badge.paid {
            background: #d1fae5;
            color: #065f46;
        }

        .status-badge.cancelled,
        .status-badge.rejected {
            background: #fee2e2;
            color: #b91c1c;
        }

        .status-badge.processing,
        .status-badge.shipped {
            background: #dbeafe;
            color: #1e40af;
        }

        .status-badge.pending {
            background: #fef3c7;
            color: #92400e;
        }

        .order-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 8px;
        }

        .total-label {
            font-size: 13px;
            color: var(--text-gray);
            margin-bottom: 4px;
            display: block;
        }

        .total-amount {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .action-buttons {
            display: flex;
            gap: 12px;
        }

        .btn-detail {
            display: inline-flex;
            align-items: center;
            padding: 10px 20px;
            background: #00B09B;
            color: white;
            font-weight: 600;
            font-size: 14px;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.2s;
            border: none;
            box-shadow: 0 4px 6px -1px rgba(0, 176, 155, 0.2);
        }

        .btn-detail:hover {
            background: #009684;
            transform: translateY(-1px);
            box-shadow: 0 6px 8px -1px rgba(0, 176, 155, 0.3);
        }

        .btn-ghost-danger {
            display: inline-flex;
            align-items: center;
            padding: 10px 16px;
            background: transparent;
            color: #ef4444;
            font-weight: 500;
            font-size: 14px;
            border-radius: 8px;
            border: 1px solid transparent;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-ghost-danger:hover {
            background: #fef2f2;
            border-color: #fee2e2;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: var(--bg-white);
            border-radius: 16px;
            border: 1px dashed var(--border);
            margin-top: 40px;
        }

        .empty-icon {
            font-size: 48px;
            margin-bottom: 16px;
            display: block;
        }
    </style>

    <div class="main-container">
        <div class="dashboard-container">
            <!-- Header & Stats -->
            <div class="dashboard-header">
                <h1 data-i18n="user.dashboard_title">Pesanan Saya</h1>
                <p><span data-i18n="user.greeting">Halo</span>, <strong>
                        <%= currentUser.full_name || currentUser.username %>
                    </strong>! <span data-i18n="user.greeting_desc">Kelola riwayat belanjaan Anda di sini.</span></p>

                <div class="dashboard-stats">
                    <div class="stat-card">
                        <div class="stat-icon blue">📦</div>
                        <div class="stat-content">
                            <h3 data-i18n="user.total_orders">Total Pesanan</h3>
                            <div class="stat-value">
                                <%= stats.totalOrders %>
                            </div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon orange">⏳</div>
                        <div class="stat-content">
                            <h3 data-i18n="user.active_orders">Pesanan Aktif</h3>
                            <div class="stat-value">
                                <%= stats.activeOrders %>
                            </div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon green">💰</div>
                        <div class="stat-content">
                            <h3 data-i18n="user.total_spent">Total Belanja</h3>
                            <div class="stat-value">Rp <%= parseInt(stats.totalSpent).toLocaleString('id-ID') %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Orders Preview -->
            <div class="section-header"
                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                <h2 class="section-title" style="margin: 0; border: none;" data-i18n="user.recent_orders">Pesanan
                    Terbaru</h2>
                <a href="/user/orders" class="btn-detail" style="padding: 8px 16px; font-size: 14px;"
                    data-i18n="user.view_all_orders">📦 Lihat Semua Pesanan</a>
            </div>


            <% if (recentOrders.length===0) { %>
                <div class="empty-state">
                    <span class="empty-icon">🛍️</span>
                    <h3 style="color: var(--text-dark); margin: 0 0 8px 0;" data-i18n="user.no_orders">
                        Belum ada pesanan</h3>
                    <p style="color: var(--text-gray); margin: 0 0 20px 0;" data-i18n="user.no_orders_desc">Yuk,
                        mulai belanja kebutuhan kesehatanmu sekarang!</p>
                    <a href="/" class="btn-detail" data-i18n="user.shop_again">🛍️ Belanja Sekarang</a>
                </div>
                <% } else { %>
                    <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 30px;">
                        <% recentOrders.forEach(order=> { %>
                            <div class="order-card" style="margin-bottom: 0;">
                                <div class="order-header" style="margin-bottom: 12px; padding-bottom: 12px;">
                                    <div class="order-info">
                                        <div class="order-icon-box">📦</div>
                                        <div class="order-details">
                                            <h3>#ORD-<%= order.id %>
                                            </h3>
                                            <p class="order-date">
                                                <%= new Date(order.createdAt).toLocaleDateString('id-ID', {
                                                    day: 'numeric' , month: 'short' , year: 'numeric' }) %>
                                            </p>
                                        </div>
                                    </div>
                                    <% var badgeClass=order.status; var i18nStatusKey='user.status_' + order.status
                                        + '_short' ; var badgeText=order.status; if (order.status==='paid' )
                                        badgeText='✅ Menunggu Dikemas' ; else if (order.status==='processing' )
                                        badgeText='⏳ Diproses' ; else if (order.status==='shipped' )
                                        badgeText='🚚 Dikirim' ; else if (order.status==='completed' )
                                        badgeText='🎉 Selesai' ; else if (order.status==='cancelled' )
                                        badgeText='❌ Dibatalkan' ; else if (order.status==='rejected' )
                                        badgeText='⛔ Ditolak' ; %>
                                        <span class="status-badge <%= badgeClass %>" data-i18n="<%= i18nStatusKey %>">
                                            <%= badgeText %>
                                        </span>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <div>
                                        <span style="font-size: 13px; color: var(--text-gray);"
                                            data-i18n="user.items_count">Item:</span>
                                        <strong>
                                            <%= order.items ? order.items.length : 0 %>
                                        </strong>
                                    </div>
                                    <a href="/orders/<%= order.id %>" class="btn-detail"
                                        style="padding: 8px 16px; font-size: 13px;"
                                        data-i18n="user.detail_invoice">Detail Invoice</a>
                                </div>
                            </div>
                            <% }); %>
                    </div>

                    <div style="text-align: center; margin-bottom: 20px;">
                        <a href="/user/orders"
                            style="color: #00B09B; font-weight: 600; text-decoration: none; font-size: 15px;"
                            data-i18n="user.see_full_history">Lihat Riwayat Lengkap →</a>
                    </div>
                    <% } %>
        </div>
    </div>

    <%- include('../partials/footer') %>