<%- include('../partials/header', { activeTab: 'profile' }) %>

    <style>
        .profile-wrapper {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .profile-header {
            text-align: center;
            margin-bottom: 32px;
        }

        .profile-title {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 8px;
        }

        .profile-subtitle {
            font-size: 15px;
            color: var(--text-gray);
        }

        .profile-card {
            background: var(--bg-white);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border);
        }

        .profile-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 32px;
        }

        @media(min-width: 768px) {
            .profile-grid {
                grid-template-columns: 300px 1fr;
                align-items: start;
            }
        }

        /* Avatar Section */
        .avatar-upload-box {
            background: var(--bg-light);
            border: 2px dashed var(--border);
            border-radius: 20px;
            padding: 32px 20px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
        }

        .avatar-upload-box:hover {
            border-color: #3b82f6;
            background: rgba(59, 130, 246, 0.08);
        }

        .avatar-preview-circle {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: var(--bg-white);
            margin: 0 auto 20px auto;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            border: 4px solid var(--bg-white);
            font-size: 48px;
        }

        .avatar-preview-circle img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Form Fields */
        .form-group label {
            display: block;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 8px;
            font-size: 14px;
        }

        .form-control {
            width: 100%;
            padding: 14px 18px;
            border-radius: 12px;
            border: 1px solid var(--border);
            transition: all 0.2s;
            font-family: inherit;
            font-size: 15px;
            background: var(--bg-white);
            color: var(--text-dark);
        }

        .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            outline: none;
        }

        button.btn-save {
            background: #3b82f6;
            color: white;
            padding: 14px 32px;
            font-size: 16px;
            font-weight: 700;
            border: none;
            border-radius: 99px;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
        }

        button.btn-save:hover {
            background: #2563eb;
        }

        button.btn-save:active {
            transform: scale(0.96);
        }
    </style>

    <div class="profile-wrapper">
        <div class="profile-header">
            <h1 class="profile-title" data-i18n="profile.title">Profil Master Pengguna</h1>
            <p class="profile-subtitle" data-i18n="profile.subtitle">Sesuaikan identitas pribadi, avatar, nomor telepon,
                dan keamanan kata sandi
                Anda.</p>
        </div>

        <div class="profile-card">
            <form action="/profile/edit" method="POST" enctype="multipart/form-data">

                <div class="profile-grid">
                    <!-- Left Column: Avatar & Role Info -->
                    <div>
                        <label
                            style="display: block; font-weight: 700; color: var(--text-dark); margin-bottom: 12px; font-size: 16px;"
                            data-i18n="profile.photo_label">Foto
                            Profil</label>
                        <div class="avatar-upload-box">
                            <div class="avatar-preview-circle">
                                <% if (user.profile_image) { %>
                                    <img src="<%= user.profile_image %>" id="avatarImgPreview">
                                    <% } else { %>
                                        <span id="avatarFallback">👤</span>
                                        <img src="" id="avatarImgPreview" style="display:none;">
                                        <% } %>
                            </div>
                            <p style="font-size: 14px; color: var(--text-gray); font-weight: 600; margin-bottom: 4px;"
                                data-i18n="profile.change_image">
                                Ubah
                                Gambar</p>
                            <p style="font-size: 12px; color: var(--text-gray); margin: 0;"
                                data-i18n="profile.max_file">Maksimal file 2MB</p>

                            <input type="file" id="avatarFileInput" name="profile_image" accept="image/*"
                                style="opacity: 0; position: absolute; top:0; left:0; width:100%; height:100%; cursor: pointer; z-index: 10;">
                        </div>

                        <!-- Avatar Crop Container -->
                        <div id="avatarCropContainer"
                            style="display:none; margin-top: 16px; background: var(--bg-light); padding: 15px; border-radius: 12px; border: 1px solid var(--border);">
                            <h4 style="margin: 0 0 10px 0; font-size: 14px; color: var(--text-dark);"
                                data-i18n="profile.photo_editor">📷 Editor Foto Profil</h4>
                            <div style="max-height: 350px; overflow: hidden; background: #333; border-radius: 8px;">
                                <img id="avatarImageToCrop" style="max-width: 100%; display: block;">
                            </div>
                            <div style="margin-top: 12px; display: flex; justify-content: flex-end; gap: 10px;">
                                <button type="button" id="btnAvatarCropCancel" class="btn-secondary"
                                    data-i18n="profile.crop_cancel">Batal</button>
                                <button type="button" id="btnAvatarCropApply" class="btn-primary"
                                    data-i18n="profile.crop_apply">Terapkan Crop</button>
                            </div>
                        </div>

                        <!-- Avatar Crop Preview -->
                        <div id="avatarCropPreview" style="display:none; margin-top: 12px;">
                            <p style="font-size: 12px; color: var(--primary); font-weight: bold;"
                                data-i18n="profile.crop_result">✅ Hasil Crop:</p>
                            <div style="display: flex; align-items: center; gap: 15px;">
                                <img id="avatarPreviewResult"
                                    style="height: 80px; width: 80px; object-fit: cover; border-radius: 50%; border: 2px solid var(--primary);">
                                <button type="button" id="btnAvatarReset"
                                    style="background: none; border: none; color: #d9534f; cursor: pointer; text-decoration: underline; font-size: 13px;"
                                    data-i18n="profile.crop_reset">Batalkan Ubahan</button>
                            </div>
                        </div>

                        <!-- Readonly Role Display -->
                        <div
                            style="margin-top: 24px; padding: 16px; background: var(--bg-light); border-radius: 12px; border: 1px solid var(--border);">
                            <span
                                style="font-size: 12px; font-weight: 700; color: var(--text-gray); text-transform: uppercase;"
                                data-i18n="profile.role_label">Peran
                                Akun Aktif</span>
                            <div
                                style="font-size: 16px; font-weight: 800; color: var(--text-dark); margin-top: 6px; display: flex; align-items: center; gap: 8px;">
                                <% if (user.role==='admin' ) { %> 🛡️ <span data-i18n="profile.role_admin">Administrator
                                        Utama</span>
                                    <% } %>
                                        <% if (user.role==='seller' ) { %> 🏪 <span
                                                data-i18n="profile.role_seller">Penjual / Merchant</span>
                                            <% } %>
                                                <% if (user.role==='customer' ) { %> 🛒 <span
                                                        data-i18n="profile.role_customer">Pelanggan Pribadi</span>
                                                    <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Details & Password -->
                    <div>
                        <!-- Section: Identitas -->
                        <h3
                            style="font-size: 18px; font-weight: 800; color: var(--text-dark); border-bottom: 2px solid var(--border); padding-bottom: 12px; margin-bottom: 24px;">
                            <span data-i18n="profile.basic_info">Informasi Dasar</span>
                        </h3>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                            <div class="form-group">
                                <label data-i18n="profile.alias">Nama Alias / Panggilan</label>
                                <input type="text" name="username" class="form-control"
                                    value="<%= user.username || '' %>" required>
                                <p style="font-size: 12px; color: var(--text-gray); margin-top: 6px;"
                                    data-i18n="profile.alias_hint">Ini akan terlihat
                                    di header
                                    Anda.</p>
                            </div>
                            <div class="form-group">
                                <label data-i18n="profile.full_name">Nama Lengkap (Asli)</label>
                                <input type="text" name="full_name" class="form-control"
                                    value="<%= user.full_name || '' %>" required>
                            </div>
                        </div>

                        <div class="form-group" style="margin-bottom: 20px;">
                            <label data-i18n="profile.email_label">Alamat Email</label>
                            <input type="email" name="email" class="form-control" value="<%= user.email || '' %>"
                                required>
                        </div>

                        <div class="form-group" style="margin-bottom: 32px;">
                            <label data-i18n="profile.phone_label">Nomor Telepon / WhatsApp Pribadi</label>
                            <input type="text" name="phone" class="form-control" value="<%= user.phone || '' %>"
                                placeholder="Contoh: 081234..." data-i18n-placeholder="profile.phone_placeholder">
                        </div>

                        <!-- Section: Address & Financial -->
                        <% if (user.role !=='admin' ) { %>
                            <div class="form-group" style="margin-bottom: 24px;">
                                <label data-i18n="profile.shipping_address">Alamat Default Pengiriman 📦</label>
                                <textarea name="address" class="form-control" rows="3"
                                    placeholder="<%= user.role==='seller' ? 'Alamat domisili pribadi Anda untuk belanja (Beda dari alamat Toko)' : 'Alamat rumah untuk penerimaan paket belanja Anda' %>"
                                    data-i18n-placeholder="<%= user.role==='seller' ? 'profile.address_placeholder_seller' : 'profile.address_placeholder_customer' %>"><%= user.role === 'customer' && user.buyer && user.buyer.shipping_address ? user.buyer.shipping_address : (user.role === 'seller' ? user.address : '') %></textarea>
                                <% if (user.role==='seller' ) { %>
                                    <p style="font-size: 12px; color: var(--text-gray); margin-top: 6px;"
                                        data-i18n="profile.address_hint_seller">Ini adalah
                                        alamat Anda
                                        sebagai pembeli. Untuk mengganti alamat Lapak/Toko, atur di tab <b>Pengaturan
                                            Toko</b>.</p>
                                    <% } %>
                            </div>
                            <% } %>

                                <% if (user.role==='seller' ) { %>
                                    <div class="form-group" style="margin-bottom: 32px;">
                                        <label data-i18n="profile.bank_account">💳 Rekening Bank / Pencairan Dana
                                            (Opsional)</label>
                                        <input type="text" name="bank_account" class="form-control"
                                            value="<%= user.seller && user.seller.bank_account ? user.seller.bank_account : '' %>"
                                            placeholder="Contoh: BCA 1234567890 a.n Anda"
                                            data-i18n-placeholder="profile.bank_placeholder">
                                        <p style="font-size: 12px; color: var(--text-gray); margin-top: 6px;"
                                            data-i18n="profile.bank_hint">Nomor
                                            rekening
                                            esensial untuk menarik saldo <i>Revenue</i> ke rekening pribadi.</p>
                                    </div>
                                    <% } %>

                                        <!-- Section: Keamanan -->
                                        <h3
                                            style="font-size: 18px; font-weight: 800; color: var(--text-dark); border-bottom: 2px solid var(--border); padding-bottom: 12px; margin-bottom: 16px;">
                                            <span data-i18n="profile.change_password">Ganti Sandi Keamanan</span>
                                        </h3>
                                        <p style="font-size: 13px; color: var(--text-gray); margin-bottom: 20px;"
                                            data-i18n="profile.password_note">
                                            Kosongkan kolom
                                            ini
                                            jika tidak ingin mengubah kata sandi lama.</p>

                                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                                            <div class="form-group">
                                                <label data-i18n="profile.new_password">Kata Sandi Baru</label>
                                                <input type="password" name="new_password" class="form-control"
                                                    placeholder="Masukan sandi baru"
                                                    data-i18n-placeholder="profile.new_password_placeholder">
                                            </div>
                                            <div class="form-group">
                                                <label data-i18n="profile.confirm_password">Konfirmasi Sandi
                                                    Baru</label>
                                                <input type="password" name="confirm_password" class="form-control"
                                                    placeholder="Ulangi sandi baru"
                                                    data-i18n-placeholder="profile.confirm_password_placeholder">
                                            </div>
                                        </div>

                                        <div style="margin-top: 40px; display: flex; justify-content: flex-end;">
                                            <button type="submit" class="btn-save">
                                                💾 <span data-i18n="profile.save">Terapkan Perubahan Profil</span>
                                            </button>
                                        </div>
                    </div>
                </div>
        </div>
        </form>

        <hr style="border: 0; border-top: 1px solid var(--border); margin: 40px 0 30px;">

        <!-- Zona Bahaya: Hapus Akun -->
        <div
            style="background-color: rgba(239, 68, 68, 0.08); padding: 24px; border-radius: 12px; border: 1px solid rgba(239, 68, 68, 0.25);">
            <h3 style="font-size: 18px; margin-top: 0; margin-bottom: 12px; color: #ef4444; font-weight: 800;"
                data-i18n="profile.danger_title">Zona
                Bahaya (Hapus Akun)</h3>
            <p style="font-size: 15px; color: var(--text-gray); margin-bottom: 20px; line-height: 1.5;"
                data-i18n="profile.danger_desc">
                Menghapus profil bersifat permanen dan tidak dapat dibatalkan. Pastikan Anda tidak memiliki tunggakan,
                transaksi aktif, atau pesanan yang tengah dikemas.
            </p>
            <div style="text-align: right;">
                <form action="/profile/delete" method="POST"
                    onsubmit="return confirmAction(event, t('profile.delete_confirm'), t('profile.yes_delete_account'), '#EF4444');">
                    <button type="submit"
                        style="background-color: #dc2626; color: white; border: none; padding: 12px 24px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: background 0.2s;"
                        data-i18n="profile.delete_account_btn">
                        🚨 Hapus Akun Saya
                    </button>
                </form>
            </div>
        </div>
    </div>
    </div>

    <!-- CropperJS CSS & JS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const avatarFileInput = document.getElementById('avatarFileInput');
            const avatarCropContainer = document.getElementById('avatarCropContainer');
            const avatarImageToCrop = document.getElementById('avatarImageToCrop');
            const btnAvatarCropCancel = document.getElementById('btnAvatarCropCancel');
            const btnAvatarCropApply = document.getElementById('btnAvatarCropApply');
            const avatarCropPreview = document.getElementById('avatarCropPreview');
            const avatarPreviewResult = document.getElementById('avatarPreviewResult');
            const btnAvatarReset = document.getElementById('btnAvatarReset');
            const avatarImgPreview = document.getElementById('avatarImgPreview');
            const avatarFallback = document.getElementById('avatarFallback');
            const profileForm = document.querySelector('form[action="/profile/edit"]');

            let avatarCropper = null;
            let avatarCroppedBlob = null;

            // Handle file selection → open cropper
            avatarFileInput.addEventListener('change', function (e) {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function (evt) {
                    avatarImageToCrop.src = evt.target.result;
                    avatarCropContainer.style.display = 'block';
                    avatarCropPreview.style.display = 'none';

                    if (avatarCropper) avatarCropper.destroy();
                    avatarCropper = new Cropper(avatarImageToCrop, {
                        aspectRatio: 1,  // 1:1 square (for round avatar)
                        viewMode: 1,
                        autoCropArea: 0.9,
                    });
                };
                reader.readAsDataURL(file);
            });

            // Cancel crop
            btnAvatarCropCancel.addEventListener('click', function () {
                avatarCropContainer.style.display = 'none';
                avatarFileInput.value = '';
                avatarCroppedBlob = null;
                if (avatarCropper) { avatarCropper.destroy(); avatarCropper = null; }
            });

            // Apply crop
            btnAvatarCropApply.addEventListener('click', function () {
                if (!avatarCropper) return;
                const canvas = avatarCropper.getCroppedCanvas({ width: 400, height: 400 });
                canvas.toBlob(function (blob) {
                    avatarCroppedBlob = blob;
                    avatarPreviewResult.src = canvas.toDataURL();

                    // Update main preview
                    avatarImgPreview.src = canvas.toDataURL();
                    avatarImgPreview.style.display = 'block';
                    if (avatarFallback) avatarFallback.style.display = 'none';

                    avatarCropContainer.style.display = 'none';
                    avatarCropPreview.style.display = 'block';

                    avatarCropper.destroy();
                    avatarCropper = null;
                }, 'image/jpeg', 0.9);
            });

            // Reset
            btnAvatarReset.addEventListener('click', function () {
                avatarCropContainer.style.display = 'none';
                avatarCropPreview.style.display = 'none';
                avatarFileInput.value = '';
                avatarCroppedBlob = null;
                if (avatarCropper) { avatarCropper.destroy(); avatarCropper = null; }
            });

            // Form submission with cropped blob
            profileForm.addEventListener('submit', function (e) {
                if (avatarCroppedBlob) {
                    e.preventDefault();
                    const formData = new FormData(profileForm);
                    formData.append('croppedAvatar', avatarCroppedBlob, 'avatar-cropped.jpg');

                    fetch('/profile/edit', { method: 'POST', body: formData })
                        .then(response => {
                            if (response.redirected) window.location.href = response.url;
                            else if (response.ok) window.location.href = '/profile';
                            else throw new Error('Upload failed');
                        })
                        .catch(err => {
                            console.error(err);
                            window.showToast && window.showToast('Upload gagal', 'error');
                        });
                }
                // If no crop, normal form submit proceeds
            });
        });
    </script>

    <%- include('../partials/footer') %>