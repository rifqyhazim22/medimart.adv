<%- include('../partials/header', { activeTab: 'chat' }) %>
    <link rel="stylesheet" href="/css/chat.css">

    <% var isBuyer=conversation.buyer_id===currentUser.id; var displayName='' ; if (isBuyer) {
        displayName=otherUser.seller && otherUser.seller.store_name ? otherUser.seller.store_name : (otherUser.full_name
        || otherUser.username); } else { displayName=otherUser.full_name || otherUser.username; } %>

        <div class="main-container">
            <div class="chat-layout">
                <div class="chat-room-container">

                    <!-- Room Header -->
                    <div class="chat-room-header">
                        <a href="/chat" class="back-btn" title="Kembali">←</a>
                        <% if (otherUser.profile_image) { %>
                            <img src="<%= otherUser.profile_image %>" alt="" class="conv-avatar"
                                style="width: 40px; height: 40px;">
                            <% } else { %>
                                <div class="conv-avatar-placeholder"
                                    style="width: 40px; height: 40px; font-size: 16px;">
                                    <%= displayName.charAt(0).toUpperCase() %>
                                </div>
                                <% } %>
                                    <div class="chat-user-info">
                                        <div class="name">
                                            <%= displayName %>
                                        </div>
                                        <% if (isBuyer && otherUser.seller && otherUser.seller.store_name) { %>
                                            <div class="store-name">🏪 <%= otherUser.full_name || otherUser.username %>
                                            </div>
                                            <% } %>
                                                <div class="typing-indicator" id="typingIndicator"
                                                    data-i18n="chat.typing">sedang mengetik...</div>
                                    </div>
                    </div>

                    <!-- Messages Area -->
                    <div class="messages-area" id="messagesArea">
                        <% if (messages.length===0) { %>
                            <div class="chat-empty" style="padding: 40px;">
                                <div class="chat-empty-icon">👋</div>
                                <h3 data-i18n="chat.start_conversation">Mulai percakapan!</h3>
                                <p data-i18n="chat.start_conversation_desc">Kirim pesan untuk memulai obrolan.</p>
                            </div>
                            <% } else { %>
                                <% var lastDate='' ; %>
                                    <% messages.forEach(function(msg, idx) { var msgDateStr=msg.createdAt ||
                                        msg.created_at; var locale=(lang==='en' ? 'en-US' : 'id-ID' ); var msgDate=new
                                        Date(msgDateStr).toLocaleDateString(locale, { day: 'numeric' , month: 'long' ,
                                        year: 'numeric' }); var msgTime=new Date(msgDateStr).toLocaleTimeString(locale,
                                        { hour: '2-digit' , minute: '2-digit' }); var
                                        isMine=msg.sender_id===currentUser.id; if (msgDate !==lastDate) {
                                        lastDate=msgDate; %>
                                        <div class="date-divider"><span>
                                                <%= msgDate %>
                                            </span></div>
                                        <% } %>

                                            <div class="message-bubble <%= isMine ? 'sent' : 'received' %>"
                                                data-msg-id="<%= msg.id %>">
                                                <% /* Context card inside bubble (product) */ %>
                                                    <% if (msg.context_type==='product' && msg.context_data) { %>
                                                        <div class="message-context-card">
                                                            <img src="<%= msg.context_data.image_url || '/img/placeholder.png' %>"
                                                                alt="">
                                                            <div class="mcc-info">
                                                                <div class="mcc-name">
                                                                    <%= msg.context_data.name %>
                                                                </div>
                                                                <div class="mcc-price">Rp <%=
                                                                        parseInt(msg.context_data.price ||
                                                                        0).toLocaleString('id-ID') %>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <% } %>
                                                            <% /* Context card inside bubble (order) */ %>
                                                                <% if (msg.context_type==='order' && msg.context_data) {
                                                                    %>
                                                                    <div class="message-context-card">
                                                                        <div
                                                                            style="width: 40px; height: 40px; border-radius: 6px; background: var(--bg-light); display: flex; align-items: center; justify-content: center; font-size: 18px;">
                                                                            📋</div>
                                                                        <div class="mcc-info">
                                                                            <div class="mcc-name">#ORD-<%=
                                                                                    msg.context_data.orderId %>
                                                                            </div>
                                                                            <div class="mcc-price">
                                                                                <%= msg.context_data.status %>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>
                                                                        <% if (msg.image_url && msg.image_url !=='null'
                                                                            && msg.image_url.trim() !=='' ) { %>
                                                                            <div class="chat-image-wrap"><img
                                                                                    src="<%= msg.image_url %>" alt="📷"
                                                                                    class="chat-bubble-image">
                                                                            </div>
                                                                            <% } %>
                                                                                <div>
                                                                                    <%= msg.message %>
                                                                                </div>
                                                                                <div class="message-time">
                                                                                    <%= msgTime %>
                                                                                        <% if (isMine) { %>
                                                                                            <span class="read-tick"
                                                                                                data-msg-id="<%= msg.id %>">
                                                                                                <% if (msg.is_read) { %>
                                                                                                    <span
                                                                                                        style="color: #34b7f1;">✓✓</span>
                                                                                                    <% } else { %><span
                                                                                                            class="unread-tick">✓✓</span>
                                                                                                        <% } %>
                                                                                            </span>
                                                                                            <% } %>
                                                                                </div>
                                            </div>
                                            <% }); %>
                                                <% } %>
                    </div>

                    <!-- Context Options Section -->
                    <% if (typeof contextProduct !=='undefined' && contextProduct) { %>
                        <div class="context-options" id="contextOptions">
                            <div class="context-banner">
                                <div class="context-banner-card">
                                    <img src="<%= contextProduct.image_url || '/img/placeholder.png' %>" alt=""
                                        style="width: 44px; height: 44px; border-radius: 8px; object-fit: cover;">
                                    <div style="flex: 1; min-width: 0;">
                                        <div
                                            style="font-weight: 700; font-size: 13px; color: var(--text-dark); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                            <%= contextProduct.name %>
                                        </div>
                                        <div style="font-size: 12px; color: #00B09B; font-weight: 600;">Rp <%=
                                                parseInt(contextProduct.price).toLocaleString('id-ID') %>
                                        </div>
                                    </div>
                                    <button onclick="dismissContext()"
                                        style="background: none; border: none; font-size: 18px; cursor: pointer; color: var(--text-gray); padding: 4px;"
                                        title="Tutup">✕</button>
                                </div>
                                <div class="quick-chips">
                                    <button class="chip" onclick="window.pickChip(this)" data-i18n="chat.chip_available"
                                        data-i18n-msg="chat.chip_available_msg">💬 Apakah masih tersedia?</button>
                                    <button class="chip" onclick="window.pickChip(this)" data-i18n="chat.chip_nett"
                                        data-i18n-msg="chat.chip_nett_msg">💰 Berapa harga nett?</button>
                                    <button class="chip" onclick="window.pickChip(this)" data-i18n="chat.chip_discount"
                                        data-i18n-msg="chat.chip_discount_msg">🏷️ Ada diskon?</button>
                                    <button class="chip" onclick="window.pickChip(this)" data-i18n="chat.chip_usage"
                                        data-i18n-msg="chat.chip_usage_msg">📋 Cara pemakaian?</button>
                                    <button class="chip" onclick="window.pickChip(this)" data-i18n="chat.chip_shipping"
                                        data-i18n-msg="chat.chip_shipping_msg">🚚 Lama pengiriman?</button>
                                </div>
                            </div>
                        </div>
                        <% } %>

                            <% if (typeof contextOrder !=='undefined' && contextOrder) { %>
                                <div class="context-options" id="contextOptions">
                                    <div class="context-banner">
                                        <div class="context-banner-card">
                                            <div
                                                style="width: 44px; height: 44px; border-radius: 8px; background: var(--bg-light); display: flex; align-items: center; justify-content: center; font-size: 22px;">
                                                📋</div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div
                                                    style="font-weight: 700; font-size: 13px; color: var(--text-dark);">
                                                    Pesanan #ORD-<%= contextOrder.id %>
                                                </div>
                                                <div style="font-size: 12px; color: #f59e0b; font-weight: 600;">
                                                    <%= contextOrder.status %>
                                                </div>
                                            </div>
                                            <button onclick="dismissContext()"
                                                style="background: none; border: none; font-size: 18px; cursor: pointer; color: var(--text-gray); padding: 4px;"
                                                title="Tutup">✕</button>
                                        </div>
                                        <div class="quick-chips">
                                            <button class="chip" onclick="window.pickChip(this)"
                                                data-i18n="chat.chip_ask_order"
                                                data-i18n-msg="chat.chip_ask_order_msg">💬 Tanya pesanan ini</button>
                                            <button class="chip" onclick="window.pickChip(this)"
                                                data-i18n="chat.chip_when_ship"
                                                data-i18n-msg="chat.chip_when_ship_msg">🚚 Kapan dikirim?</button>
                                            <button class="chip" onclick="window.pickChip(this)"
                                                data-i18n="chat.chip_processed"
                                                data-i18n-msg="chat.chip_processed_msg">⏳ Sudah diproses?</button>
                                            <button class="chip" onclick="window.pickChip(this)"
                                                data-i18n="chat.chip_change" data-i18n-msg="chat.chip_change_msg">✏️
                                                Ubah pesanan?</button>
                                        </div>
                                    </div>
                                </div>
                                <% } %>



                                    <!-- Chat Input -->
                                    <div id="imagePreviewContainer"
                                        style="display: none; padding: 8px 16px; background: var(--bg-light); border-top: 1px solid var(--border); align-items: center; gap: 8px;">
                                        <div style="position: relative; display: inline-block;">
                                            <img id="imagePreviewImg" src=""
                                                style="height: 56px; width: 56px; border-radius: 6px; object-fit: cover; border: 1px solid var(--border); display: block;">
                                            <button onclick="clearImagePreview()"
                                                style="position: absolute; top: -5px; right: -5px; width: 18px; height: 18px; border-radius: 50%; background: #ef4444; color: white; border: none; font-size: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1;">✕</button>
                                        </div>
                                        <span style="font-size: 12px; color: var(--text-gray);"
                                            data-i18n="chat.msg_ready">📎 Gambar siap
                                            dikirim</span>
                                    </div>

                                    <div class="chat-input-area">
                                        <input type="file" id="chatImageInput" accept="image/*" style="display: none;">
                                        <button class="chat-attach-btn" id="attachBtn" title="Lampirkan Gambar"
                                            onclick="document.getElementById('chatImageInput').click()">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                stroke-linejoin="round">
                                                <path
                                                    d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48" />
                                            </svg>
                                        </button>
                                        <input type="text" id="messageInput" placeholder="Ketik pesan..."
                                            data-i18n-placeholder="chat.type_message" autocomplete="off"
                                            maxlength="1000">
                                        <button class="chat-send-btn" id="sendBtn" title="Kirim">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                                stroke-linejoin="round">
                                                <line x1="22" y1="2" x2="11" y2="13"></line>
                                                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                                            </svg>
                                        </button>
                                    </div>

                </div>
            </div>
        </div>

        <!-- Socket.IO Client -->
        <script src="/socket.io/socket.io.js"></script>

        <!-- Hidden Data Div for Context Data -->
        <div id="server-context-data" style="display:none;" <% if (typeof contextProduct !=='undefined' &&
            contextProduct) { %>
            data-type="product" data-json="<%= JSON.stringify({ productId: contextProduct.id, name: contextProduct.name,
                price: parseFloat(contextProduct.price), image_url: contextProduct.image_url || '' }) %>"
                <% } else if (typeof contextOrder !=='undefined' && contextOrder) { %>
                    data-type="order" data-json="<%= JSON.stringify({ orderId: contextOrder.id, status:
                        contextOrder.status || '' }) %>"
                        <% } %>
                            ></div>

        <script>
            // Context data (from server)
            var pendingContext = null;
            var ctxDataEl = document.getElementById('server-context-data');
            if (ctxDataEl && ctxDataEl.getAttribute('data-type') && ctxDataEl.getAttribute('data-json')) {
                try {
                    pendingContext = {
                        type: ctxDataEl.getAttribute('data-type'),
                        data: JSON.parse(ctxDataEl.getAttribute('data-json'))
                    };
                } catch (e) {
                    console.error('Failed to parse context data', e);
                }
            }

            window.pickChip = function (btn) {
                try {
                    var msgKey = btn.getAttribute('data-i18n-msg');
                    var msg = '';
                    if (msgKey && typeof t === 'function') {
                        var translated = t(msgKey);
                        if (translated && translated !== msgKey && typeof translated !== 'object') {
                            msg = translated;
                        }
                    }

                    if (!msg) {
                        msg = btn.textContent.trim().replace(/^[\u2700-\u27BF]|[\uE000-\uF8FF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDFFF]|[\u2011-\u26FF]|\uD83E[\uDD10-\uDDFF]/g, '').trim();
                        if (!msg) msg = btn.textContent.trim();
                    }
                    var messageInput = document.getElementById('messageInput');
                    if (messageInput) {
                        messageInput.value = msg;
                        messageInput.focus();
                    }

                    document.querySelectorAll('.chip').forEach(function (c) { c.classList.remove('selected'); });
                    btn.classList.add('selected');
                } catch (e) {
                    console.error('Error in chip click:', e);
                }
            };

            function dismissContext() {
                var el = document.getElementById('contextOptions');
                if (el) el.remove();
                pendingContext = null;
                window.history.replaceState({}, '', window.location.pathname);
            }

            var pendingImageUrl = null;

            function clearImagePreview() {
                pendingImageUrl = null;
                document.getElementById('imagePreviewContainer').style.display = 'none';
                document.getElementById('imagePreviewImg').src = '';
                document.getElementById('chatImageInput').value = '';
            }

            // Image upload handler
            document.getElementById('chatImageInput').addEventListener('change', function () {
                var file = this.files[0];
                if (!file) return;
                var formData = new FormData();
                formData.append('chat_image', file);

                // Show preview immediately
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imagePreviewImg').src = e.target.result;
                    document.getElementById('imagePreviewContainer').style.display = 'flex';
                };
                reader.readAsDataURL(file);

                // Upload to server
                fetch('/api/chat/upload-image', { method: 'POST', body: formData })
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        if (d.success) {
                            pendingImageUrl = d.image_url;
                        } else {
                            clearImagePreview();
                            if (window.showToast) window.showToast(t('chat.upload_failed'), 'error');
                        }
                    })
                    .catch(function () {
                        clearImagePreview();
                        if (window.showToast) window.showToast(t('chat.upload_failed'), 'error');
                    });
            });

            (function () {
                var socket = io({ transports: ['polling', 'websocket'] });
                var conversationId = Number('<%= conversation.id %>');
                var currentUserId = Number('<%= currentUser.id %>');
                var messagesArea = document.getElementById('messagesArea');
                var messageInput = document.getElementById('messageInput');
                var sendBtn = document.getElementById('sendBtn');
                var typingIndicator = document.getElementById('typingIndicator');
                var typingTimeout = null;

                // Join conversation room
                socket.emit('join-conversation', conversationId);

                // Scroll to bottom
                function scrollToBottom() {
                    messagesArea.scrollTop = messagesArea.scrollHeight;
                }
                scrollToBottom();

                // Send message (with optional context + image)
                function sendMessage() {
                    var msg = messageInput.value.trim();
                    if (!msg && !pendingImageUrl) return;

                    var payload = {
                        conversationId: conversationId,
                        message: msg || '📷 Gambar'
                    };

                    // Attach pending context if present
                    if (pendingContext) {
                        payload.contextType = pendingContext.type;
                        payload.contextData = pendingContext.data;
                        pendingContext = null;
                        dismissContext();
                    }

                    // Attach image if present
                    if (pendingImageUrl && pendingImageUrl !== 'null' && pendingImageUrl.trim() !== '') {
                        payload.image_url = pendingImageUrl;
                        clearImagePreview();
                    }

                    socket.emit('send-message', payload);

                    messageInput.value = '';
                    socket.emit('stop-typing', conversationId);
                }

                sendBtn.addEventListener('click', sendMessage);
                messageInput.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        sendMessage();
                    }
                });

                // Typing
                messageInput.addEventListener('input', function () {
                    socket.emit('typing', conversationId);
                    clearTimeout(typingTimeout);
                    typingTimeout = setTimeout(function () {
                        socket.emit('stop-typing', conversationId);
                    }, 2000);
                });

                // Receive message
                socket.on('new-message', function (data) {
                    if (data.conversation_id !== conversationId) return;

                    // Remove empty state if exists
                    var emptyState = messagesArea.querySelector('.chat-empty');
                    if (emptyState) emptyState.remove();

                    var isMine = data.sender_id === currentUserId;

                    var bubble = document.createElement('div');
                    bubble.className = 'message-bubble ' + (isMine ? 'sent' : 'received');
                    bubble.setAttribute('data-msg-id', data.id);

                    var html = '';

                    // Context card in bubble
                    if (data.context_type === 'product' && data.context_data) {
                        html += '<div class="message-context-card">';
                        html += '<img src="' + (data.context_data.image_url || '/img/placeholder.png') + '" alt="">';
                        html += '<div class="mcc-info">';
                        html += '<div class="mcc-name">' + escapeHtml(data.context_data.name) + '</div>';
                        html += '<div class="mcc-price">Rp ' + parseInt(data.context_data.price || 0).toLocaleString('id-ID') + '</div>';
                        html += '</div></div>';
                    }

                    if (data.context_type === 'order' && data.context_data) {
                        html += '<div class="message-context-card">';
                        html += '<div style="width:40px;height:40px;border-radius:6px;background:var(--bg-light);display:flex;align-items:center;justify-content:center;font-size:18px;">📋</div>';
                        html += '<div class="mcc-info">';
                        html += '<div class="mcc-name">#ORD-' + data.context_data.orderId + '</div>';
                        html += '<div class="mcc-price">' + escapeHtml(data.context_data.status || '') + '</div>';
                        html += '</div></div>';
                    }

                    var timeStr = data.createdAt || data.created_at || new Date();
                    var locale = (typeof lang !== 'undefined' ? (lang === 'en' ? 'en-US' : 'id-ID') : (localStorage.getItem('medimart_lang') === 'en' ? 'en-US' : 'id-ID'));
                    var time = new Date(timeStr).toLocaleTimeString(locale, { hour: '2-digit', minute: '2-digit' });


                    // Image in bubble
                    if (data.image_url && data.image_url !== 'null' && data.image_url.trim() !== '') {
                        html += '<div class="chat-image-wrap"><img src="' + data.image_url + '" alt="📷" class="chat-bubble-image"></div>';
                    }

                    html += '<div>' + escapeHtml(data.message) + '</div>';
                    html += '<div class="message-time">' + time;
                    if (isMine) {
                        html += ' <span class="read-tick" data-msg-id="' + data.id + '"><span class="unread-tick">✓✓</span></span>';
                    }
                    html += '</div>';

                    bubble.innerHTML = html;
                    messagesArea.appendChild(bubble);
                    scrollToBottom();

                    // Mark as read if not mine
                    if (!isMine) {
                        socket.emit('mark-read', conversationId);
                    }
                });

                // Read receipt — other user read my messages
                socket.on('messages-read', function (data) {
                    if (data.conversationId === conversationId) {
                        // Turn all unread ticks to blue
                        var unreadTicks = document.querySelectorAll('.unread-tick');
                        for (var i = 0; i < unreadTicks.length; i++) {
                            unreadTicks[i].style.color = '#34b7f1';
                            unreadTicks[i].className = '';
                        }
                    }
                });

                // Typing indicator
                socket.on('user-typing', function (data) {
                    if (data.userId !== currentUserId) {
                        typingIndicator.style.display = 'block';
                    }
                });

                socket.on('user-stop-typing', function (data) {
                    if (data.userId !== currentUserId) {
                        typingIndicator.style.display = 'none';
                    }
                });

                // Unread badge update — update the header badge
                socket.on('unread-update', function (data) {
                    var badge = document.getElementById('chatBadge');
                    if (badge) {
                        // Fetch total unread
                        fetch('/api/chat/unread')
                            .then(function (r) { return r.json(); })
                            .then(function (d) {
                                if (d.unread > 0) {
                                    badge.innerText = d.unread;
                                    badge.style.display = 'flex';
                                } else {
                                    badge.style.display = 'none';
                                }
                            })
                            .catch(function () { });
                    }
                });

                // Mark as read on entry
                socket.emit('mark-read', conversationId);

                // Escape HTML
                function escapeHtml(str) {
                    if (!str) return '';
                    var div = document.createElement('div');
                    div.textContent = str;
                    return div.innerHTML;
                }
            })();
        </script>

        <%- include('../partials/footer') %>